{
	"info": {
		"_postman_id": "academix-api-collection",
		"name": "AcademiX API",
		"description": "Colección completa para probar la API REST de AcademiX.\n\n**Flujo recomendado:**\n1. Registrar un usuario (`Auth > Registrar`)\n2. Hacer login (`Auth > Login`) → el token se guarda automáticamente\n3. Probar los demás endpoints autenticados\n\n**Variables de colección:**\n- `base_url`: URL base del servidor (default: `http://localhost:9090`)\n- `access_token`: Se auto-rellena tras login/registro\n- `refresh_token`: Se auto-rellena tras login/registro",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:9090",
			"type": "string"
		},
		{
			"key": "access_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "refresh_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "user_id",
			"value": "1",
			"type": "string"
		},
		{
			"key": "note_id",
			"value": "1",
			"type": "string"
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{access_token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Auth",
			"description": "Endpoints de autenticación: registro, login y renovación de token.",
			"item": [
				{
					"name": "Registrar usuario",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.accessToken) {",
									"        pm.collectionVariables.set('access_token', jsonData.accessToken);",
									"    }",
									"    if (jsonData.refreshToken) {",
									"        pm.collectionVariables.set('refresh_token', jsonData.refreshToken);",
									"    }",
									"    pm.test('Usuario registrado correctamente', function () {",
									"        pm.response.to.have.status(201);",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"nombreUsuario\": \"testuser\",\n    \"correo\": \"test@academix.com\",\n    \"contrasena\": \"password123\",\n    \"nombreCompleto\": \"Test User\",\n    \"carrera\": \"Ingeniería Informática\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/register",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "register"]
						}
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.accessToken) {",
									"        pm.collectionVariables.set('access_token', jsonData.accessToken);",
									"    }",
									"    if (jsonData.refreshToken) {",
									"        pm.collectionVariables.set('refresh_token', jsonData.refreshToken);",
									"    }",
									"    pm.test('Login correcto', function () {",
									"        pm.response.to.have.status(200);",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"usuarioOCorreo\": \"testuser\",\n    \"contrasena\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "login"]
						}
					},
					"response": []
				},
				{
					"name": "Renovar Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.accessToken) {",
									"        pm.collectionVariables.set('access_token', jsonData.accessToken);",
									"    }",
									"    if (jsonData.refreshToken) {",
									"        pm.collectionVariables.set('refresh_token', jsonData.refreshToken);",
									"    }",
									"    pm.test('Token renovado correctamente', function () {",
									"        pm.response.to.have.status(200);",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Refresh-Token",
								"value": "{{refresh_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/auth/refresh",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "refresh"]
						}
					},
					"response": []
				}
			]
		},
